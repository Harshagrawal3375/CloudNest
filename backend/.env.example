PORT=5000
JWT_SECRET=your_jwt_secret_here
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/cloudnest
BOT_TOKEN=your_telegram_bot_token_here
CHANNEL_USERNAME=your_telegram_channel_id_here
FRONTEND_URL=http://localhost:3000

# Email (optional - if not set, emails are logged to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=CloudNest <noreply@cloudnest.app>
